<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:YesHybrid.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1020" d:DesignHeight="760"
        x:Class="YesHybrid.Desktop.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Yes Hybrid"
        MinWidth="700"
        MinHeight="520">
  <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,*">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,0,8">
      <TextBlock Text="Mode" VerticalAlignment="Center" Opacity="0.85" />
      <ComboBox x:Name="ModeCombo" Width="200" />
      <TextBlock x:Name="YouPlayLabel" Text="You play" VerticalAlignment="Center" Opacity="0.85" Margin="8,0,0,0" />
      <ComboBox x:Name="SideCombo" Width="200" />
      <Button x:Name="NewGameButton" Content="New game" MinWidth="88" />
      <Button x:Name="RulesButton" Content="Rules…" MinWidth="88" />
    </StackPanel>
    <TextBlock Grid.Row="1"
               Text="{Binding StatusText}"
               TextWrapping="Wrap"
               FontSize="14" />
    <TextBlock Grid.Row="2"
               Text="{Binding ErrorText}"
               TextWrapping="Wrap"
               Foreground="Crimson"
               Margin="0,4,0,0"
               IsVisible="{Binding ErrorVisible}" />
    <Grid Grid.Row="3" ColumnDefinitions="*,280" MinHeight="200">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <ContentControl x:Name="BoardHost" />
      </ScrollViewer>
      <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="0">
        <TextBlock Text="Move list" FontWeight="Bold" />
        <ListBox x:Name="HistoryList"
                 MinHeight="180"
                 MaxHeight="360"
                 FontFamily="ui-monospace, Consolas, monospace"
                 ItemsSource="{Binding HistoryLines}" />
        <TextBlock Text="Result" FontWeight="Bold" Margin="0,12,0,4" />
        <TextBlock Text="{Binding ResultText}" TextWrapping="Wrap" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
